# =====================================================
# Juzhi API Platform - 环境变量配置
# 复制此文件为 .env 并填入实际值
# =====================================================

# 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ai_platform?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root123456

# Redis 配置 (可选，默认 localhost:6379)
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
# SPRING_REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=JuzhiAPIPlatformSecretKey2024ForJWTTokenGenerationAndValidation!
JWT_EXPIRATION=86400000

# AI 网关配置 (New API / One API)
AI_GATEWAY_URL=http://localhost:3000
AI_GATEWAY_API_KEY=sk-your-gateway-api-key-here

# 限流配置 (每分钟请求数)
RATE_LIMIT_PER_MINUTE=60

# 每日最大消耗 credits (1元 = 10000 credits)
DAILY_MAX_COST=10000000
